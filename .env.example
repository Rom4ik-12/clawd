# ─── Telegram Userbot ────────────────────────────────────────────────────────
TG_API_ID=0
TG_API_HASH=your_api_hash_here
SESSION_NAME=clawd

# ─── Panel Bot ────────────────────────────────────────────────────────────────
PANEL_BOT_TOKEN=your_bot_token_here

# ─── Owner ────────────────────────────────────────────────────────────────────
OWNER_ID=0
OWNER_NAME=Владелец

# ─── LLM Providers (OpenAI-compatible) ───────────────────────────────────────
# OpenRouter — основной провайдер
OPENROUTER_API_KEY=

# Codex.sale — резервный (много бесплатных моделей)
CODEXSALE_API_KEY=

# Runic — дополнительный
RUNIC_API_KEY=

# ─── Custom OpenAI-compatible API ────────────────────────────────────────────
# Любой OpenAI-совместимый эндпоинт. Если не нужен — оставь пустым.
#
# Примеры:
#   Ollama (локально):    CUSTOM_API_BASE_URL=http://localhost:11434/v1
#                         CUSTOM_API_MODEL=llama3.3:70b
#                         CUSTOM_API_KEY=ollama
#
#   LMStudio (локально):  CUSTOM_API_BASE_URL=http://localhost:1234/v1
#                         CUSTOM_API_MODEL=lmstudio-community/Meta-Llama-3.1-8B
#                         CUSTOM_API_KEY=lmstudio
#
#   Groq:                 CUSTOM_API_BASE_URL=https://api.groq.com/openai/v1
#                         CUSTOM_API_MODEL=llama-3.3-70b-versatile
#                         CUSTOM_API_KEY=gsk_...
#
#   Together AI:          CUSTOM_API_BASE_URL=https://api.together.xyz/v1
#                         CUSTOM_API_MODEL=meta-llama/Llama-3-70b-chat-hf
#                         CUSTOM_API_KEY=...
#
#   Mistral:              CUSTOM_API_BASE_URL=https://api.mistral.ai/v1
#                         CUSTOM_API_MODEL=mistral-large-latest
#                         CUSTOM_API_KEY=...
CUSTOM_API_BASE_URL=
CUSTOM_API_MODEL=
CUSTOM_API_KEY=dummy

# ─── SearXNG ─────────────────────────────────────────────────────────────────
# Публичный инстанс по умолчанию. Поставь свой если есть.
SEARXNG_URL=https://searx.be

# ─── Settings ─────────────────────────────────────────────────────────────────
TIMEZONE=Europe/Moscow
